APP_ENV=prod
DEFAULT_TIMEZONE=Asia/Shanghai
DATABASE_URL=sqlite:////app/data/reminder.db
SCHEDULER_SCAN_INTERVAL_SECONDS=60

# Optional: primary LLM provider
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: fallback provider
MODELSCOPE_API_KEY=
MODELSCOPE_MODEL=Qwen/Qwen2.5-72B-Instruct
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# Optional: Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE=https://api.telegram.org

# Optional: SMTP email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Optional: WeCom app messaging
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_BASE_URL=https://qyapi.weixin.qq.com
WECOM_TOKEN=
WECOM_AES_KEY=
